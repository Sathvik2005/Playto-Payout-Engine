DJANGO_SECRET_KEY=replace-with-a-long-random-secret-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=playto-payout-engine.onrender.com,localhost,127.0.0.1

DB_ENGINE=django.db.backends.postgresql
DB_NAME=playto_payouts
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=your-render-postgres-host
DB_PORT=5432

CELERY_BROKER_URL=redis://your-render-redis-host:6379/0
CELERY_RESULT_BACKEND=redis://your-render-redis-host:6379/1
CELERY_TASK_ALWAYS_EAGER=False
CORS_ALLOWED_ORIGINS=https://your-vercel-app.vercel.app,http://localhost:5173
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ACCESS_TTL_SECONDS=3600

# Production security settings (enable when deploying)
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
